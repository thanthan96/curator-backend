{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // tell TS about ambient Node.js symbols (process, global, Buffer, etc.)
    "types": ["node"],

    // optional, but useful
    "rootDir": "lib",
    "outDir": "dist"
  },
  "include": ["lib/**/*.ts", "lib/**/*.tsx"],
  "exclude": ["node_modules"]
}
